{
  "name": "3dprintforge-poc-react-parts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Proof-of-concept: the Projects/Production 'Parts' panel rebuilt in Vite + React + TypeScript, talking to the live 3DPrintForge JSON API. Isolated from the main app — nothing here affects it.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
