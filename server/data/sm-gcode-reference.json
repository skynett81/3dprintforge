{
  "_source": "Snapmaker/Documentation + u1-klipper + Snapmaker2-Controller",
  "commands": {
    "M2000": { "desc": "SACP protocol switch", "params": "S5 P1 = enable SACP (Artisan/J1), U5 = enable SACP (Ray)", "machines": ["J1", "Artisan", "Ray"] },
    "M1010": { "desc": "Enclosure LED control", "params": "S0 = off, S1 = on", "machines": ["Artisan", "A150", "A250", "A350"] },
    "M1011": { "desc": "Enclosure fan control", "params": "S0-S100 = speed percent", "machines": ["Artisan"] },
    "AUTO_FEEDING": { "desc": "Auto-load filament", "params": "CHANNEL=0-3", "machines": ["U1"] },
    "MANUAL_FEEDING": { "desc": "Manual filament extrude", "params": "CHANNEL=0-3", "machines": ["U1"] },
    "INNER_FILAMENT_UNLOAD": { "desc": "Unload filament from extruder", "params": "CHANNEL=0-3", "machines": ["U1"] },
    "DEFECT_DETECTION_CONFIG": { "desc": "AI defect detection settings", "params": "MAIN_ENABLE=0|1, NOODLE_ENABLE=0|1, CLEAN_BED_ENABLE=0|1, RESIDUE_ENABLE=0|1, NOZZLE_CHECK_ENABLE=0|1, sensitivity: HIGH|LOW", "machines": ["U1"] },
    "DEFECT_DETECTION_DETECT_BED": { "desc": "Trigger bed cleanliness check", "params": "(none)", "machines": ["U1"] },
    "TIMELAPSE_START": { "desc": "Start timelapse recording", "params": "TYPE=new|continue", "machines": ["U1"] },
    "TIMELAPSE_STOP": { "desc": "Stop timelapse", "params": "(none)", "machines": ["U1"] },
    "TIMELAPSE_TAKE_FRAME": { "desc": "Capture single timelapse frame", "params": "(none)", "machines": ["U1"] },
    "SET_PRINT_AUTO_BED_LEVELING": { "desc": "Enable/disable auto bed leveling before print", "params": "ENABLE=0|1", "machines": ["U1"] },
    "SET_PRINT_FLOW_CALIBRATION": { "desc": "Enable/disable flow calibration before print", "params": "ENABLE=0|1", "machines": ["U1"] },
    "SET_PRINT_SHAPER_CALIBRATION": { "desc": "Enable/disable input shaper calibration before print", "params": "ENABLE=0|1", "machines": ["U1"] },
    "SET_TIME_LAPSE_CAMERA": { "desc": "Enable/disable timelapse during print", "params": "ENABLE=0|1", "machines": ["U1"] },
    "SET_PURIFIER": { "desc": "Purifier control", "params": "ON|OFF, SPEED=0-100", "machines": ["U1"] },
    "GET_PURIFIER": { "desc": "Query purifier status", "params": "(none)", "machines": ["U1"] },
    "BED_MESH_CALIBRATE": { "desc": "Run bed mesh calibration", "params": "(standard Klipper)", "machines": ["U1"] },
    "SHAPER_CALIBRATE": { "desc": "Run input shaper calibration", "params": "AXIS=X|Y", "machines": ["U1"] },
    "AUTO_SCREWS_TILT_ADJUST": { "desc": "Auto-adjust bed screws using probe", "params": "(none)", "machines": ["U1"] },
    "XYZ_OFFSET_CALIBRATE_ALL": { "desc": "Calibrate XYZ offsets for all extruders", "params": "(none)", "machines": ["U1"] },
    "EXTRUDER_OFFSET_ACTION_PROBE_CALIBRATE_ALL": { "desc": "Probe-based multi-extruder offset calibration", "params": "(none) — takes ~5 min", "machines": ["U1"] },
    "ROUGHLY_CLEAN_NOZZLE": { "desc": "Quick nozzle cleaning routine", "params": "(none)", "machines": ["U1"] },
    "QUERY_PARK_STA": { "desc": "Query extruder park state", "params": "NAME=t0|t1|t2|t3", "machines": ["U1"] },
    "QUERY_ADC_CURRENT": { "desc": "Query motor current sensor", "params": "SENSOR=heater_bed|extruder", "machines": ["U1"] },
    "ENABLE_POWER_LOSS": { "desc": "Enable power loss recovery", "params": "(none)", "machines": ["U1"] },
    "FILAMENT_DT_QUERY": { "desc": "Query all filament detection channels", "params": "(none)", "machines": ["U1"] },
    "FILAMENT_DT_UPDATE": { "desc": "Force NFC re-read on all channels", "params": "(none)", "machines": ["U1"] },
    "M605": { "desc": "IDEX mode", "params": "S0 = single mode (use T0/T1), S2 = duplicate, S3 = mirror, S4 = backup", "machines": ["J1"] },
    "M104": { "desc": "Set nozzle temperature", "params": "S<temp> T<extruder>", "machines": ["all"] },
    "M140": { "desc": "Set bed temperature", "params": "S<temp>", "machines": ["all"] },
    "M106": { "desc": "Set fan speed", "params": "S0-S255", "machines": ["all"] },
    "M112": { "desc": "Emergency stop", "params": "(none)", "machines": ["all"] },
    "M220": { "desc": "Set speed override", "params": "S<percent> (e.g. S100)", "machines": ["all"] },
    "G28": { "desc": "Home all axes", "params": "X Y Z (optional axis selection)", "machines": ["all"] }
  }
}
